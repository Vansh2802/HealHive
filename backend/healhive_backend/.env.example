# =============================================================================
# HealHive — Environment Variable Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control — it is listed in .gitignore.
# =============================================================================

# ── Django core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-strong-random-secret-min-50-chars
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ── CORS / CSRF ───────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── JWT ───────────────────────────────────────────────────────────────────────
# Used internally by simplejwt; must match DJANGO_SECRET_KEY in practice.
# Set explicitly here if you ever override simplejwt's signing key.
JWT_SECRET=replace-with-your-jwt-signing-secret

# ── Redis (Django Channels broker) ───────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/1

# ── MongoDB (real-time chat message store) ────────────────────────────────────
# For local dev use the default localhost URI.
# For production use your Atlas connection string (never commit the real value).
MONGO_URI=mongodb://127.0.0.1:27017
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=healhive_chat
MONGODB_MESSAGES_COLLECTION=messages
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=0
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# ── App base URL ──────────────────────────────────────────────────────────────
APP_BASE_URL=http://127.0.0.1:8000

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
# Obtain from Google Cloud Console → APIs & Services → Credentials.
# Never commit real values — keep them only in your local .env or a secret manager.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_PROJECT_ID=healhive

# ── AI / LLM API keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CREWAI_MODEL=gpt-4o-mini

# ── SMTP email ────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=HealHive <your-email@gmail.com>

# =============================================================================
# Frontend (Vite) environment variables
# These belong in frontend/.env — Vite only exposes VITE_* prefixed vars.
# =============================================================================

# Backend REST API base URL consumed by the React frontend
VITE_API_URL=http://localhost:8000/api

# WebSocket base URL consumed by the React chat adapter
VITE_WS_URL=ws://localhost:8000

# Set to '0' in production to suppress WS debug logs
VITE_WS_DEBUG=1
