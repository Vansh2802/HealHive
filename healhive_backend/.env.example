# Django backend
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173
REDIS_URL=redis://127.0.0.1:6379/1
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=healhive_chat
MONGODB_MESSAGES_COLLECTION=messages
APP_BASE_URL=http://127.0.0.1:8000

# If you call Anthropic directly from Django (recommended), store key here
ANTHROPIC_API_KEY=sk-ant-your-key-here
CREWAI_MODEL=gpt-4o-mini

# SMTP email settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=HealHive <your-email@gmail.com>
